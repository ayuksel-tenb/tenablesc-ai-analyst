# Copy to .env and fill in. Never commit the real .env.

# --- Tenable Security Center ---
SC_HOST=https://securitycenter.local
SC_ACCESS_KEY=your-access-key
SC_SECRET_KEY=your-secret-key
# TLS verification: false (self-signed), true, or a path to a CA bundle.
SC_VERIFY=false

# --- Write tools ---
# When true, the side-effecting tools (accept/recast risk, ticket, launch scan)
# are registered. Leave false for a read-only analyst.
SC_ENABLE_WRITES=false
